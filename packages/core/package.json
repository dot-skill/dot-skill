{
  "name": "@skillerr/core",
  "version": "0.6.0",
  "description": "Compile, pack, validate, and mint portable .skill packages",
  "license": "MIT",
  "author": {
    "name": "Bharat Dudeja",
    "url": "https://github.com/bharatdudeja13-cmd"
  },
  "keywords": [
    "skill",
    ".skill",
    "ai-agents",
    "agent-skills",
    "compile",
    "mint"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dot-skill/dot-skill.git",
    "directory": "packages/core"
  },
  "homepage": "https://skillerr.com",
  "bugs": {
    "url": "https://github.com/dot-skill/dot-skill/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc",
    "prepack": "npm run build",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@skillerr/protocol": "^0.6.0",
    "fflate": "^0.8.2"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^5.4.5"
  }
}
