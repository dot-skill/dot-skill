{
  "name": "@skillerr/registry",
  "version": "0.6.0",
  "description": "Optional local transparency log for .skill package digests",
  "license": "MIT",
  "author": {
    "name": "Bharat Dudeja",
    "url": "https://github.com/bharatdudeja13-cmd"
  },
  "keywords": [
    "skill",
    ".skill",
    "ai-agents",
    "transparency-log",
    "registry"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dot-skill/skillerr.git",
    "directory": "packages/registry"
  },
  "homepage": "https://skillerr.com",
  "bugs": {
    "url": "https://github.com/dot-skill/skillerr/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc",
    "prepack": "npm run build",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@skillerr/core": "^0.6.0",
    "@skillerr/protocol": "^0.6.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^5.4.5"
  }
}
